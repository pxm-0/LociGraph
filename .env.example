# Database
POSTGRES_PASSWORD=changeme            # owner role 'locigraph' — migrations only
APP_DB_PASSWORD=changeme              # non-owner role 'locigraph_app' — app + workers

# Auth (used in Plan 3)
JWT_SECRET=changeme-generate-with-openssl-rand-hex-32
LOCIGRAPH_EMAIL=you@example.com
LOCIGRAPH_PASSWORD=changeme

# AI (Plan/Phase 1+)
ACTIVE_AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
CLAIM_EXTRACTION_AUTORUN=false
CLAIM_EXTRACTION_BATCH_SIZE=12
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_AUTORUN=false
EMBEDDING_BATCH_SIZE=100
OPENAI_CONTRADICTION_MODEL=gpt-4o-mini
CONTRADICTION_CANDIDATE_LIMIT=5
CONTRADICTION_SIMILARITY_FLOOR=0.75
CONTRADICTION_AUTORUN=false

# Storage
RAW_STORAGE_PATH=/data/raw
RAW_RETENTION_DAYS=7

# Redis
REDIS_URL=redis://redis:6379

# Deployment (all optional — defaults match local dev)
# Override host ports when 80/5432/6379 are already taken on a shared host.
CADDY_PORT=80
POSTGRES_PORT=5432
REDIS_PORT=6379
# Set to false when Caddy isn't terminating TLS (e.g. a private-network
# deployment reached over plain HTTP) — a secure cookie is never sent back
# by the browser over a non-HTTPS connection, which breaks login.
COOKIE_SECURE=true
